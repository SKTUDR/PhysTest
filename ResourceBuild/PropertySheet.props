<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Label="PropertySheets" />
  <PropertyGroup Label="UserMacros">
    <dds>DDS/</dds>
    <cmo>CMO/</cmo>
  </PropertyGroup>
  <PropertyGroup />
  <ItemDefinitionGroup>
    <ImageContentTask>
      <Compress>BC7_UNORM_SRGB</Compress>
    </ImageContentTask>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup>
    <ImageContentTask>
      <ContentOutput>$(dds)%(Filename).dds</ContentOutput>
    </ImageContentTask>
    <MeshContentTask>
      <ContentOutput>$(cmo)%(Filename).cmo</ContentOutput>
    </MeshContentTask>
    <PostBuildEvent>
      <Command>call "$(ProjectDir)Tools\CmoPathCut.bat" "$(ProjectDir)"</Command>
    </PostBuildEvent>
  </ItemDefinitionGroup>
  <ItemGroup>
    <BuildMacro Include="dds">
      <Value>$(dds)</Value>
    </BuildMacro>
    <BuildMacro Include="cmo">
      <Value>$(cmo)</Value>
    </BuildMacro>
  </ItemGroup>
</Project>